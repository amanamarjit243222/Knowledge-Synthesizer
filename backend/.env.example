# =============================================
# Knowledge Synthesizer - Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# --- SERVER CONFIG ---
HOST=0.0.0.0
PORT=8000

# --- AUDIO PROCESSING ---
# Path to FFmpeg binary (required for audio file conversion).
# On Linux/Mac, if ffmpeg is on PATH, leave this commented out.
# On Windows, set the full path:
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe

# --- CORS CONFIG ---
# Comma-separated list of allowed origins. Use "*" for development ONLY.
# In production, restrict to your frontend domain:
# ALLOWED_ORIGINS=https://your-frontend-domain.com
ALLOWED_ORIGINS=*

# --- OPTIONAL: AI PROVIDER (for future Whisper/Gemini integration) ---
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...
